# Example environment variables for docker-compose
# Copy this to .env and fill in your values

# Your email for Let's Encrypt notifications
EMAIL=admin@example.com

# Domain to obtain certificate for
DOMAIN=example.com

# Wildcard domain (optional)
WILDCARD_DOMAIN=*.example.com

# OpusDNS API key (or use credentials file)
OPUSDNS_API_KEY=opk_xxxxxxxxxxxxxxxxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx_xxxxxx

# API endpoint (optional, defaults to https://api.opusdns.com)
# OPUSDNS_API_ENDPOINT=https://sandbox.opusdns.com
